<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>VitalRouter.R3</id>
    <version>2.7.1</version>
    <authors>hadashiA</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <readme>README.md</readme>
    <projectUrl>https://github.com/hadashiA/VitalRouter</projectUrl>
    <description>VitalRouter extensions for R3 reactive extensions</description>
    <repository type="git" url="https://github.com/hadashiA/VitalRouter" commit="5c6cd79aad43bb3f128230e89aa282b59cde4a69" />
    <dependencies>
      <group targetFramework="net8.0">
        <dependency id="VitalRouter" version="2.7.1" exclude="Build,Analyzers" />
        <dependency id="R3" version="1.3.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net9.0">
        <dependency id="VitalRouter" version="2.7.1" exclude="Build,Analyzers" />
        <dependency id="R3" version="1.3.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.1">
        <dependency id="VitalRouter" version="2.7.1" exclude="Build,Analyzers" />
        <dependency id="R3" version="1.3.0" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>